# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — Dashboard > Developers > API Keys (Phase 2, use TEST mode keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `stripe listen` (local) or the Dashboard webhook endpoint (deployed)
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: signing secret of the SECOND webhook endpoint scoped to "Connected accounts"
# (connect=true), same /api/stripe/webhook URL — required to receive connected-account
# `account.updated` events. Leave unset if you only use the platform ("Your account") endpoint.
STRIPE_WEBHOOK_SECRET_CONNECT=whsec_...
# Price IDs from Stripe Dashboard > Products (test mode)
STRIPE_PRICE_BEGINNER_COURSE=price_...
STRIPE_PRICE_EXPERIENCED_TEST=price_...
STRIPE_PRICE_SUBSCRIPTION=price_...
# One-time $9.99 price for the public Activity Planner. REQUIRED. mode=payment, so this
# MUST be a one_time price (NOT recurring). The mode must match STRIPE_SECRET_KEY above.
STRIPE_PRICE_ONE_EVENT_LICENSE=price_...

# Email — Resend. REQUIRED for email delivery (the /api/cron/email-dispatch worker drains the
# email_notifications queue through Resend). Both must be set together; if either is absent the
# worker no-ops gracefully and no email is sent. EMAIL_FROM must be a verified Resend sender.
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@activitahub.com

# OpenAI — AI Request Understanding (OPE). All server-only; optional.
# When OPE_AI_UNDERSTANDING_ENABLED != "true" or the key is absent, OPE falls back to
# the deterministic request mapping (identical behaviour). Pricing/budget/lifecycle/
# proposal are never affected — AI only normalizes the PlannerInput.
# OPE_AI_UNDERSTANDING_ENABLED=true
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# OpenAI — AI Organizer (the first OPE interpreter). When OPE_AI_AGENT_ENABLED != "true"
# or OPENAI_API_KEY is absent, the Organizer falls back to the deterministic verdict
# (assessRequest) — fail-safe, biased to discovery, never invents a WSH or plan. Requires
# OPENAI_API_KEY (and uses OPENAI_MODEL) above.
# OPE_AI_AGENT_ENABLED=true

# Web push (VAPID) — recommended. Generate a pair: `npx web-push generate-vapid-keys`.
# Public/private keys must be from the SAME pair. Without these, browser push is disabled
# (the in-app notification inbox still works). VAPID_SUBJECT is a mailto: contact.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Scheduled jobs — REQUIRED in every deployed environment. Vercel Cron sends this as a
# Bearer token to /api/cron/*. If unset, the guard is skipped and those endpoints are
# publicly callable. Generate a strong value: `openssl rand -base64 32`.
CRON_SECRET=

# Optional providers — safe to omit for beta (each is off / degrades gracefully when unset).
# GOOGLE_PLACES_API_KEY=     # venue place lookup; the provider returns null without it
# SUPPLIER_DISCOVERY_URL=    # vendor supplier discovery; disabled unless set

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
