# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — Dashboard > Developers > API Keys (Phase 2, use TEST mode keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `stripe listen` (local) or the Dashboard webhook endpoint (deployed)
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from Stripe Dashboard > Products (test mode)
STRIPE_PRICE_BEGINNER_COURSE=price_...
STRIPE_PRICE_EXPERIENCED_TEST=price_...
STRIPE_PRICE_SUBSCRIPTION=price_...

# Email — Resend (added in Phase 6B)
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@activitahub.com

# OpenAI — AI Request Understanding (OPE). All server-only; optional.
# When OPE_AI_UNDERSTANDING_ENABLED != "true" or the key is absent, OPE falls back to
# the deterministic request mapping (identical behaviour). Pricing/budget/lifecycle/
# proposal are never affected — AI only normalizes the PlannerInput.
# OPE_AI_UNDERSTANDING_ENABLED=true
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
